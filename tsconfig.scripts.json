{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": ".scripts-dist",
    "rootDir": ".",
    "paths": {
      "@/*": ["../src/*"]
    }
  },
  "include": ["scripts/**/*.ts"],
  "exclude": ["node_modules", ".next", "src"]
}
