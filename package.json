{
  "name": "lakecomo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "sanity:introspect": "tsx --tsconfig tsconfig.scripts.json scripts/sanity/introspect-schemas.ts",
    "sanity:export": "tsx --tsconfig tsconfig.scripts.json scripts/sanity/export-dataset.ts",
    "sanity:diff": "tsx --tsconfig tsconfig.scripts.json scripts/sanity/diff-dataset.ts",
    "sanity:plan": "tsx --tsconfig tsconfig.scripts.json scripts/sanity/generate-migration-plan.ts",
    "sanity:seed": "tsx --tsconfig tsconfig.scripts.json scripts/sanity/seed-from-json.ts",
    "sanity:seed:dry-run": "tsx --tsconfig tsconfig.scripts.json scripts/sanity/seed-from-json.ts --dry-run",
    "sanity:verify-assets": "tsx --tsconfig tsconfig.scripts.json scripts/sanity/verify-assets.ts",
    "sanity:rollback": "tsx --tsconfig tsconfig.scripts.json scripts/sanity/rollback.ts",
    "sanity:rollback:list": "tsx --tsconfig tsconfig.scripts.json scripts/sanity/rollback.ts list",
    "sanity:generate-types": "tsx --tsconfig tsconfig.scripts.json scripts/sanity/generate-types.ts",
    "sanity:discover-queries": "tsx --tsconfig tsconfig.scripts.json scripts/sanity/discover-queries.ts",
    "sanity:validate": "tsx --tsconfig tsconfig.scripts.json scripts/sanity/validate-schema.ts",
    "sanity:migrate": "npm run sanity:rollback -- snapshot && npm run sanity:diff && npm run sanity:plan && npm run sanity:seed"
  },
  "dependencies": {
    "@sanity/image-url": "^1.2.0",
    "@sanity/vision": "^4.22.0",
    "@types/nodemailer": "^7.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "focus-trap-react": "^11.0.4",
    "framer-motion": "^12.23.26",
    "lenis": "^1.3.17",
    "lucide-react": "^0.562.0",
    "next": "^16.2.0",
    "next-sanity": "^11.6.12",
    "nodemailer": "^7.0.12",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sanity": "^4.22.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@sanity/client": "^6.29.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
